      {
        "path": "vmux_terminal::shell_env",
        "docs_md": "Capture the user's login-shell environment so agent processes inherit it.\n\nA vmux terminal runs the user's shell, which sources its config (`env.nu`,\n`.zshrc`, …) and thus has the user's exported vars (API keys, etc.). An\n*agent* (vibe/claude/codex) is launched as a bare executable, so it only\ninherits the daemon's environment — which is missing those vars when the\ndaemon was started by launchd rather than from a shell. We capture the login\nshell's exported environment once and merge it into agent spawns.",
        "items": [
          {
            "kind": "function",
            "name": "login_shell_env",
            "path": "vmux_terminal::shell_env::login_shell_env",
            "signature": "pub fn login_shell_env(shell: &str) -> &'static [(String, String)]",
            "docs_md": "The environment the user's login shell exports, captured once per process.",
            "members": [],
            "links": []
          },
          {
            "kind": "function",
            "name": "merge_login_shell_env",
            "path": "vmux_terminal::shell_env::merge_login_shell_env",
            "signature": "pub fn merge_login_shell_env(env: &mut Vec<(String, String)>, shell: &str)",
            "docs_md": "Merge the login-shell env into `env` (shell values win), then drop duplicate\nkeys keeping the last. Use when spawning an agent so it gets the same\nenvironment a terminal would, regardless of how the daemon was launched.",
            "members": [],
            "links": []
          }
        ],
        "submodules": []
      },
