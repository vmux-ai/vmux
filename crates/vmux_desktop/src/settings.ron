(
    browser: (
        startup_url: "https://www.google.com",
    ),
    layout: (
        radius: 0.0,
    ),
    shortcuts: (
        leader: (key: "b", ctrl: true),
        chord_timeout_ms: 1000,
        bindings: [
            (command: "stack_next", binding: Direct((key: "Tab", ctrl: true))),
            (command: "stack_previous", binding: Direct((key: "Tab", ctrl: true, shift: true))),
            (command: "split_v", binding: Leader((key: "%"))),
            (command: "split_h", binding: Leader((key: "\""))),
            (command: "toggle_pane", binding: Leader((key: "o"))),
            (command: "close_pane", binding: Leader((key: "x"))),
            (command: "stack_new", binding: Leader((key: "c"))),
            (command: "stack_close", binding: Leader((key: "&"))),
            (command: "zoom_pane", binding: Leader((key: "z"))),
            (command: "select_pane_left", binding: Leader((key: "h"))),
            (command: "select_pane_down", binding: Leader((key: "j"))),
            (command: "select_pane_up", binding: Leader((key: "k"))),
            (command: "select_pane_right", binding: Leader((key: "l"))),
            (command: "select_pane_left", binding: Leader((key: "ArrowLeft"))),
            (command: "select_pane_down", binding: Leader((key: "ArrowDown"))),
            (command: "select_pane_up", binding: Leader((key: "ArrowUp"))),
            (command: "select_pane_right", binding: Leader((key: "ArrowRight"))),
            (command: "swap_pane_prev", binding: Leader((key: "{"))),
            (command: "swap_pane_next", binding: Leader((key: "}"))),
            (command: "rotate_forward", binding: Leader((key: "o", ctrl: true))),
            (command: "rotate_backward", binding: Leader((key: "o", alt: true))),
            (command: "terminal_copy_mode", binding: Leader((key: "["))),
        ],
    ),
    terminal: Some((
        default_theme: "default",
        confirm_close: true,
        themes: [
            (
                name: "default",
                color_scheme: "catppuccin-mocha",
                font_family: "JetBrainsMono Nerd Font",
                font_size: 14.0,
                line_height: 1.2,
                padding: 4.0,
                cursor_style: "block",
                cursor_blink: true,
                shell: "/opt/homebrew/bin/nu",
            ),
        ],
    )),
    auto_update: true,
    agent: (
        app_providers: [
            (provider: "stub", kind: "vibe", models: ["echo"]),
        ],
    ),
)
