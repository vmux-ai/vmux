(
    browser: (
        startup_url: "https://www.google.com",
    ),
    layout: (
        window: (
            padding: 8.0,
        ),
        pane: (
            gap: 4.0,
            radius: 8.0,
            outline: (
                width: 2.0,
                color: (r: 0.78, g: 0.40, b: 0.92),
                glow: (
                    spread: 3.0,
                    intensity: 0.35,
                ),
                gradient: (
                    enabled: true,
                    speed: 1.2,
                    cycles: 2.0,
                    accent: (r: 0.15, g: 0.55, b: 1.0),
                ),
            ),
        ),
        side_sheet: (
            width: 280.0,
        ),
    ),
    keybindings: (
        chord_timeout_ms: 1000,
        bindings: [
            (command: "tab_next", binding: Direct((key: "Tab", ctrl: true))),
            (command: "tab_previous", binding: Direct((key: "Tab", ctrl: true, shift: true))),
            (command: "split_v", binding: Chord((key: "b", ctrl: true), (key: "%"))),
            (command: "split_h", binding: Chord((key: "b", ctrl: true), (key: "\""))),
            (command: "toggle_pane", binding: Chord((key: "b", ctrl: true), (key: "o"))),
            (command: "close_pane", binding: Chord((key: "b", ctrl: true), (key: "x"))),
            (command: "toggle_side_sheet", binding: Chord((key: "b", ctrl: true), (key: "s"))),
            (command: "tab_new", binding: Chord((key: "b", ctrl: true), (key: "c"))),
            (command: "tab_close", binding: Chord((key: "b", ctrl: true), (key: "&"))),
            (command: "zoom_pane", binding: Chord((key: "b", ctrl: true), (key: "z"))),
            (command: "select_pane_left", binding: Chord((key: "b", ctrl: true), (key: "ArrowLeft"))),
            (command: "select_pane_right", binding: Chord((key: "b", ctrl: true), (key: "ArrowRight"))),
            (command: "select_pane_up", binding: Chord((key: "b", ctrl: true), (key: "ArrowUp"))),
            (command: "select_pane_down", binding: Chord((key: "b", ctrl: true), (key: "ArrowDown"))),
            (command: "swap_pane_prev", binding: Chord((key: "b", ctrl: true), (key: "{"))),
            (command: "swap_pane_next", binding: Chord((key: "b", ctrl: true), (key: "}"))),
            (command: "rotate_forward", binding: Chord((key: "b", ctrl: true), (key: "o", ctrl: true))),
            (command: "rotate_backward", binding: Chord((key: "b", ctrl: true), (key: "o", alt: true))),
        ],
    ),
)
