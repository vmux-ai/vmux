[package]
name = "bevy_cef_core"
description = "Core library for bevy_cef"
version.workspace = true
edition.workspace = true
license.workspace = true
authors.workspace = true
repository.workspace = true
readme.workspace = true
keywords.workspace = true
categories.workspace = true

[dependencies]
bevy = { version = "0.19.0", default-features = false, features = ["bevy_log", "bevy_window", "bevy_asset", "bevy_picking"], optional = true }
bevy_remote = { version = "0.19.0", default-features = false, features = ["bevy_asset", "bevy_render"], optional = true }
bevy_winit = { version = "0.19.0", default-features = false, features = ["x11", "wayland"], optional = true }
uuid = { version = "1", features = ["v4"] }
cef = { version = "148.2.0", default-features = false }
cef-dll-sys = { version = "148.2.0", features = ["sandbox"] }
serde = { workspace = true, features = ["derive"] }
serde_json = { workspace = true }
async-channel = { version = "2.5", optional = true }
raw-window-handle = { version = "0.6", optional = true }
smallvec = { workspace = true }
winit = { version = "0.30", default-features = false, optional = true }

[target.'cfg(target_os = "macos")'.dependencies]
objc2 = { version = "0.6", optional = true }
objc2-app-kit = { version = "0.3", default-features = false, features = ["std", "NSView", "NSResponder", "NSGraphics", "NSGlassEffectView", "NSColor", "NSWindow", "objc2-core-foundation", "objc2-core-graphics", "objc2-quartz-core"], optional = true }
objc2-foundation = { version = "0.3", features = ["NSGeometry", "NSString", "NSURL"], optional = true }
objc2-quartz-core = { version = "0.3", default-features = false, features = ["std", "CALayer", "CAShapeLayer", "objc2-core-graphics"], optional = true }
objc2-core-graphics = { version = "0.3", default-features = false, features = ["std", "CGPath", "CGImage", "CGColorSpace", "CGContext", "CGBitmapContext"], optional = true }
objc2-core-foundation = { version = "0.3", default-features = false, features = ["std", "CFBase"], optional = true }
objc2-av-foundation = { version = "0.3", default-features = false, features = ["std", "AVPlayer", "AVPlayerItem", "objc2-core-media"], optional = true }
objc2-av-kit = { version = "0.3", default-features = false, features = ["std", "AVPlayerView", "objc2-app-kit", "objc2-av-foundation"], optional = true }

[features]
default = ["browser-process"]
browser-process = ["dep:async-channel", "dep:bevy", "dep:bevy_remote", "dep:bevy_winit", "dep:raw-window-handle", "dep:winit", "cef/accelerated_osr", "cef/sandbox", "dep:objc2", "dep:objc2-app-kit", "dep:objc2-foundation", "dep:objc2-quartz-core", "dep:objc2-core-graphics", "dep:objc2-core-foundation"]
native-video-overlay = ["browser-process", "dep:objc2-av-foundation", "dep:objc2-av-kit"]
debug = []
